# Copy to .env on the server and fill in real values. Do NOT commit .env.

# Public hostname Caddy will serve and obtain TLS for.
# Use a real domain pointed at the server's IP, or :80 for plain HTTP testing.
DOMAIN=divemap.example.com

# Postgres
POSTGRES_DB=divemap
POSTGRES_USER=divemap
POSTGRES_PASSWORD=replace-with-long-random-string

# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
JWT_SECRET=replace-with-long-random-string
